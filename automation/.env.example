# Email (SMTP) — required
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-user@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=Daily Posts <your-user@gmail.com>
EMAIL_TO=recipient1@example.com,recipient2@example.com

# Buffer — required only if you also want to auto-queue to Buffer
BUFFER_ACCESS_TOKEN=your-buffer-personal-access-token
BUFFER_PROFILE_IDS=profile_id_1,profile_id_2
IMAGE_RAW_BASE=https://raw.githubusercontent.com/tarisha-starr/GitHub-folder/main

# YouTube — required only for fetch_outliers.py (Level 1 find-outliers skill)
# Create a key at https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
